        /* CSS 变量与动态主题渐变基础 */
        :root {
            --bg-color: #FAF9F6; /* 默认浅色 (Phase 1) */
            --text-main: #1A1A1A;
            --text-muted: #666666;
            --card-bg: #FFFFFF;
            --card-border: rgba(0, 0, 0, 0.08);
            --accent: #FF5A5F;
        }

        /* 动态主题类：由 JS 根据滚动位置动态切换 */
        body.theme-light {
            --bg-color: #FAF9F6;
            --text-main: #1A1A1A;
            --text-muted: #666666;
            --card-bg: #FFFFFF;
            --card-border: rgba(0, 0, 0, 0.08);
            --accent: #E54B4B;
        }
        body.theme-brand {
            --bg-color: #E8F0E4; /* O2O 阶段生机绿 */
            --text-main: #112A18;
            --text-muted: #3B5A44;
            --card-bg: rgba(255,255,255,0.6);
            --card-border: rgba(17, 42, 24, 0.1);
            --accent: #276338;
        }
        body.theme-dark {
            --bg-color: #0A0A0A; /* 成熟期与 AI 极客深色 */
            --text-main: #F0F0F0;
            --text-muted: #888888;
            --card-bg: #141414;
            --card-border: rgba(255, 255, 255, 0.1);
            --accent: #DCF836;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Inter', sans-serif; }
        
        body { 
            background-color: var(--bg-color); 
            color: var(--text-main); 
            line-height: 1.6; 
            transition: background-color 0.8s ease, color 0.8s ease; /* 背景色平滑渐变核心 */
            overflow-x: hidden;
        }

        h1, h2, h3, .heading-font { font-family: 'Space Grotesk', sans-serif; }
        .section-wrapper { padding: 4rem 5%; max-width: 1400px; margin: 0 auto; }

        /* 元素滑入动效 (Scroll Reveal) */
        .reveal { opacity: 0; transform: translateY(40px); transition: all 0.8s cubic-bezier(0.16, 1, 0.3, 1); }
        .reveal.active { opacity: 1; transform: translateY(0); }
        .delay-1 { transition-delay: 0.1s; }
        .delay-2 { transition-delay: 0.2s; }

        /* --- Nav & Hero --- */
        nav { display: flex; justify-content: space-between; align-items: center; padding: 2rem 5%; border-bottom: 1px solid var(--card-border); transition: border-color 0.8s ease; }
        .logo { font-size: 1.5rem; font-weight: 700; letter-spacing: -1px; }
        .nav-tags span { font-size: 0.8rem; color: var(--text-muted); border: 1px solid var(--card-border); padding: 0.4rem 1rem; border-radius: 20px; margin-left: 0.5rem; transition: all 0.8s ease; }

        .hero { display: flex; align-items: center; gap: 4rem; padding: 6rem 5% 4rem; max-width: 1400px; margin: 0 auto; min-height: 80vh;}
        .hero-text h1 { font-size: 4.5rem; line-height: 1.1; margin-bottom: 1.5rem; letter-spacing: -2px; }
        .hero-text p { font-size: 1.25rem; color: var(--text-muted); max-width: 650px; margin-bottom: 2rem; }
        .hero-image { width: 220px; height: 220px; border-radius: 50%; object-fit: cover; filter: grayscale(100%); transition: filter 0.5s ease, transform 0.5s ease; border: 4px solid var(--card-border); }
        .hero-image:hover { filter: grayscale(0%); transform: scale(1.05); }

        /* --- 技能矩阵 (The Arsenal) --- */
        .skills-matrix { margin-bottom: 3rem; }
        .skills-matrix h4 { font-size: 0.9rem; text-transform: uppercase; letter-spacing: 1px; color: var(--text-muted); margin-bottom: 1rem; }
        .skill-tags { display: flex; flex-wrap: wrap; gap: 1rem; margin-bottom: 2rem;}
        .skill-pill { padding: 0.6rem 1.2rem; background: var(--card-bg); border: 1px solid var(--card-border); border-radius: 8px; font-weight: 500; font-size: 0.95rem; display: flex; align-items: center; gap: 0.5rem; transition: all 0.3s ease;}
        .skill-pill:hover { border-color: var(--accent); color: var(--accent); transform: translateY(-3px);}
        .icon-svg { width: 18px; height: 18px; fill: currentColor; }

        /* --- Bento Box Grid --- */
