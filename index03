        .bento-card { background-color: var(--card-bg); border: 1px solid var(--card-border); border-radius: 24px; padding: 2.5rem; transition: all 0.5s ease; display: flex; flex-direction: column; overflow: hidden; backdrop-filter: blur(10px);}
