        .slider-container::-webkit-scrollbar-track { background: var(--card-border); border-radius: 10px; }
        .slider-container::-webkit-scrollbar-thumb { background: var(--text-muted); border-radius: 10px; }
        .slider-container img { height: 260px; width: auto; object-fit: contain; border-radius: 12px; scroll-snap-align: start; border: 1px solid var(--card-border); background-color: rgba(0,0,0,0.05); }

