        .hover-item { padding: 2.5rem 0; border-bottom: 1px solid var(--card-border); display: grid; grid-template-columns: 1fr 3fr; gap: 2rem; transition: padding 0.3s ease; }
        .hover-item:hover { padding-left: 1rem; }
